<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Waypoint — Panic Never Wins</title>
<meta name="description" content="Waypoint proves you survive panic attacks. Every attack you get through becomes evidence — a growing, undeniable case against fear.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,600&display=swap" rel="stylesheet">
<style>
  :root {
    --night: #0D1117;
    --abyss: #080C12;
    --surface: #111827;
    --surface-raised: #1E2A3A;
    --border: #2D3E52;
    --compass: #64B5F6;
    --survive: #3D7A5E;
    --survive-bright: #6FBF95;
    --warm-white: #F0EDE6;
    --muted: #8A9BB0;
    --ghost: #4A5568;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background: var(--night);
    color: var(--warm-white);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .display {
    font-family: "Fraunces", Georgia, serif;
  }

  a { color: var(--compass); }
  a:focus-visible, button:focus-visible {
    outline: 2px solid var(--compass);
    outline-offset: 3px;
  }

  .wrap {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Nav */
  nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13,17,23,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(45,62,82,0.5);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    max-width: 1040px;
    margin: 0 auto;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 17px;
    letter-spacing: 0.2px;
  }
  .brand svg { display: block; }
  nav a.nav-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
  }
  nav a.nav-link:hover { color: var(--warm-white); }

  /* Hero */
  header.hero {
    position: relative;
    padding: 96px 24px 88px;
    text-align: center;
    overflow: hidden;
  }

  .breathing-orb {
    position: relative;
    width: 260px;
    height: 260px;
    margin: 0 auto 8px;
  }
  .ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(100,181,246,0.35);
  }
  .ring.r1 { animation: breathe 7s ease-in-out infinite; }
  .ring.r2 { inset: 30px; border-color: rgba(100,181,246,0.5); animation: breathe 7s ease-in-out infinite 0.15s; }
  .ring.r3 {
    inset: 60px;
    background: radial-gradient(circle at 40% 35%, rgba(100,181,246,0.55), rgba(100,181,246,0.12) 70%);
    border: none;
    animation: breathe 7s ease-in-out infinite 0.3s;
  }
  .star {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .star svg { width: 46px; height: 46px; opacity: 0.95; }

  @keyframes breathe {
    0%, 100% { transform: scale(0.86); opacity: 0.75; }
    50% { transform: scale(1.06); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ring { animation: none !important; transform: scale(1); }
  }

  .eyebrow {
    color: var(--survive-bright);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  h1.headline {
    font-size: clamp(36px, 6vw, 58px);
    font-weight: 300;
    line-height: 1.08;
    margin: 0 0 22px;
    color: var(--warm-white);
  }
  h1.headline strong {
    font-weight: 600;
    color: var(--warm-white);
  }

  .sub {
    max-width: 560px;
    margin: 0 auto 40px;
    font-size: 18px;
    color: var(--muted);
  }

  .cta-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 14px;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    color: var(--warm-white);
    font-size: 15px;
    font-weight: 500;
  }
  .badge .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--survive-bright);
    box-shadow: 0 0 0 4px rgba(111,191,149,0.15);
  }
  .badge-live {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 14px;
    background: var(--compass);
    color: var(--night);
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: filter 0.15s ease;
  }
  .badge-live:hover { filter: brightness(1.08); }
  .badge-live svg { flex-shrink: 0; }
  /* Sections */
  section { padding: 88px 24px; }
  section.alt { background: var(--surface); }

  .section-head {
    max-width: 620px;
    margin: 0 auto 56px;
    text-align: center;
  }
  .section-head h2 {
    font-family: "Fraunces", Georgia, serif;
    font-weight: 300;
    font-size: clamp(28px, 4vw, 38px);
    margin: 0 0 16px;
  }
  .section-head p {
    color: var(--muted);
    font-size: 16px;
    margin: 0;
  }

  /* Evidence card mock */
  .evidence-demo {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }
  .evidence-card {
    width: 100%;
    max-width: 380px;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    text-align: center;
  }
  .evidence-number {
    font-family: "Fraunces", Georgia, serif;
    font-size: 56px;
    font-weight: 600;
    color: var(--survive-bright);
    line-height: 1;
  }
  .evidence-label {
    color: var(--muted);
    font-size: 14px;
    margin-top: 8px;
  }
  .evidence-quote {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 15px;
    color: var(--warm-white);
  }

  /* Protocol steps */
  .steps {
    max-width: 720px;
    margin: 0 auto;
    counter-reset: step;
  }
  .step {
    display: flex;
    gap: 24px;
    padding: 28px 0;
    border-bottom: 1px solid var(--border);
  }
  .step:last-child { border-bottom: none; }
  .step-num {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--compass);
    color: var(--compass);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Fraunces", Georgia, serif;
    font-size: 16px;
  }
  .step-body h3 {
    margin: 0 0 6px;
    font-size: 17px;
    font-weight: 600;
  }
  .step-body p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
  }

  /* Crisis strip — quiet, single line, not a full section */
  .crisis-strip {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .crisis-strip-inner {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 24px;
    flex-wrap: wrap;
  }
  .crisis-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--compass);
    box-shadow: 0 0 0 3px rgba(100,181,246,0.15);
  }
  .crisis-strip p {
    margin: 0;
    font-size: 13.5px;
    color: var(--muted);
  }
  .crisis-strip strong {
    color: var(--warm-white);
    font-weight: 600;
  }

  /* Footer */
  footer {
    padding: 48px 24px 64px;
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: 1040px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: space-between;
    align-items: center;
  }
  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
  }
  .footer-links a:hover { color: var(--warm-white); }
  .disclaimer {
    max-width: 1040px;
    margin: 32px auto 0;
    font-size: 13px;
    color: var(--ghost);
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    header.hero { padding: 64px 20px 56px; }
    section { padding: 64px 20px; }
    .breathing-orb { width: 200px; height: 200px; }
    .ring.r2 { inset: 22px; }
    .ring.r3 { inset: 46px; }
  }
</style>
</head>
